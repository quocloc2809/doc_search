# API Gateway Environment Variables

# Gateway Port
GATEWAY_PORT=3001

# Frontend URL (thay bằng IP/domain thực tế)
FRONTEND_URL=http://10.2.18.33:5173

# Security
REQUIRE_AUTH=true
JWT_SECRET=replace-me-with-random-32-chars-secret
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Microservices URLs (các service chạy cùng máy nên dùng localhost)
AUTH_SERVICE_URL=http://localhost:3002
DOCUMENTS_SERVICE_URL=http://localhost:3003
DEPARTMENTS_SERVICE_URL=http://localhost:3004
FILES_SERVICE_URL=http://localhost:3005

# Environment
NODE_ENV=production

# Backend production trial configuration

# Common
NODE_ENV=production
FRONTEND_URL=https://your-frontend-domain.example

# Security
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRES_IN=8h
REQUIRE_AUTH=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# API Gateway
GATEWAY_PORT=3001
AUTH_SERVICE_URL=http://localhost:3002
DOCUMENTS_SERVICE_URL=http://localhost:3003
DEPARTMENTS_SERVICE_URL=http://localhost:3004
FILES_SERVICE_URL=http://localhost:3005

# Database (shared)
DB_SERVER=your-sql-server-host
DB_DATABASE=VEC_PORTALOFFICE8_NEW
DB_USER=app_user
DB_PASSWORD=replace-with-strong-password
DB_PORT=1433
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=false

# Seed users script safety (optional)
ALLOW_INSECURE_DEFAULT_USERS=false
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=replace-admin-password
DEFAULT_USER1_USERNAME=user1
DEFAULT_USER1_PASSWORD=replace-user-password

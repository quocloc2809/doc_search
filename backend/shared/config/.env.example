# Shared Database Configuration
# Nếu SQL Server chạy cùng máy thì DB_SERVER=localhost, ngược lại điền IP SQL Server
DB_SERVER=localhost
DB_NAME=VEC_PORTALOFFICE8_NEW
# Optional: DB năm 2020 (nếu muốn lấy dữ liệu 2020 từ DB riêng)
# Ví dụ: DB_NAME_2020=VEC-PO2020
DB_NAME_2020=
# Optional: nhiều DB archive theo năm (ưu tiên hơn DB_NAME_2020)
# Ví dụ: DB_ARCHIVE_DATABASES=2020=VEC-PO2020,2019=VEC-PO2019
DB_ARCHIVE_DATABASES=
# Optional: pattern tên DB nếu đặt theo mẫu (dùng khi không muốn liệt kê hết)
# Ví dụ: DB_ARCHIVE_PATTERN=VEC-PO{year}
DB_ARCHIVE_PATTERN=
DB_USER=sa
DB_PASSWORD=your_password_here
DB_PORT=1433
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=true
